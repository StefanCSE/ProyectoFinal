{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    {
      "source": "/products(.*)",
      "destination": "server.js"
    },
    {
      "source": "/cart(.*)",
      "destination": "server.js"
    },
    {
      "source": "/checkout(.*)",
      "destination": "server.js"
    },
    {
      "source": "/(.*)",
      "destination": "/public/$1"
    }
  ]
}